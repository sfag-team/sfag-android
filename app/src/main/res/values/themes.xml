<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- windowBackground must match surfaceContainerLowestLight in Color.kt -->
    <style name="Theme.AutoGram" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <!-- windowSplashScreenBackground must match surfaceContainerLowestLight in Color.kt -->
    <style name="Theme.AutoGram.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="postSplashScreenTheme">@style/Theme.AutoGram</item>
    </style>
</resources>
